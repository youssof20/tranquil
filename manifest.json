{
  "manifest_version": 3,
  "name": "Tranquil – All-in-One Distraction Remover",
  "short_name": "Tranquil",
  "version": "1.0.1",
  "description": "A clean, focused browsing experience by removing feeds and distractions from popular social platforms.",
  "permissions": [
    "storage",
    "declarativeNetRequest",
    "scripting",
    "contextMenus",
    "tabs"
  ],
  "optional_host_permissions": [
    "*://*.youtube.com/*",
    "*://*.reddit.com/*",
    "*://*.instagram.com/*",
    "*://*.twitter.com/*",
    "*://*.x.com/*",
    "*://*.facebook.com/*",
    "*://*.linkedin.com/*",
    "*://*.amazon.com/*",
    "*://*.amazon.co.uk/*",
    "*://*.amazon.ca/*",
    "*://*.amazon.de/*",
    "*://*.amazon.fr/*",
    "*://*.amazon.it/*",
    "*://*.amazon.es/*",
    "*://*.amazon.co.jp/*"
  ],
  "background": {
    "service_worker": "background/service_worker.js"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    },
    "default_title": "Tranquil",
    "default_popup": "popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*",
        "*://*.reddit.com/*",
        "*://*.instagram.com/*",
        "*://*.twitter.com/*",
        "*://*.x.com/*",
        "*://*.facebook.com/*",
        "*://*.linkedin.com/*",
        "*://*.amazon.com/*",
        "*://*.amazon.co.uk/*",
        "*://*.amazon.ca/*",
        "*://*.amazon.de/*",
        "*://*.amazon.fr/*",
        "*://*.amazon.it/*",
        "*://*.amazon.es/*",
        "*://*.amazon.co.jp/*"
      ],
      "js": ["content/engine.js", "content/element-picker.js"],
      "css": ["content/engine.css"],
      "run_at": "document_start"
    }
  ],
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "web_accessible_resources": [
    {
      "resources": ["recipes/*.json"],
      "matches": ["<all_urls>"]
    }
  ]
}
