{
"update_url": "https://clients2.google.com/service/update2/crx",

  "manifest_version": 3,
  "default_locale": "en",

  "name": "__MSG_extension_name__",
  "description": "__MSG_extension_description__",
  "version": "9.7",
  
  "icons": {
    "48": "images/icon-48.png",
    "96": "images/icon-96.png",
    "128": "images/icon-128.png",
    "256": "images/icon-256.png",
    "512": "images/icon-512.png"
  },
  
  "background": {
    "service_worker": "extension/scripts/background.js"
  },
  
  "browser_specific_settings": {
    "gecko": {
      "id": "{2662ff67-b302-4363-95f3-b050218bd72c}"
    }
  },
  
  "content_scripts": [
    {
      "all_frames": true,

      "js": [
        "global/globalHelpers.js",
        "global/storageConstants.js",

        "extension/scripts/appVars.js",
        "extension/scripts/syncMethods.js",
        "extension/scripts/serverMethods.js",
        "extension/scripts/extensionHelpers.js",

        "global/options/contentScriptOptionsMethod.js",

        "website/js/libs/mutation-summary.js",
        "website/js/libs/purify.js",

        "website/js/override/videoElementControlsOverride.js",

        "website/js/AttributesManager/htmlAtrributesManager.js",

        "website/js/ScriptInjection/videoQualityScriptInjection.js",
        "website/js/ScriptInjection/skipAdsScriptInjection.js",

        "website/js/Dynamic/dynamicOberver.js",
        "website/js/Dynamic/dynamicShortsPage.js",
        "website/js/Dynamic/dynamicVideoPage.js",
        "website/js/Dynamic/dynamicSearchPage.js",
        "website/js/Dynamic/dynamicHomePage.js",
        "website/js/Dynamic/dynamicChannelPage.js",

        "website/js/VideoSummarize/summarize-utils.js",
        "website/js/VideoSummarize/video-summarize-container-view-manager.js",
        "website/js/VideoSummarize/select-handlers.js",
        "website/js/VideoSummarize/add-summarize-button.js",

        "website/js/VideoSummarize/video-summarize-window.js",
        "website/js/VideoSummarize/get-summarize-video-content.js",

        "website/js/StyleManager/cssStyleManager.js",
        "website/js/StyleManager/disabledAdditionalOptions.js",

        "website/js/Font/font.js",
        "website/js/AccentColor/accentColor.js",

        "website/js/ThumbnailFilter/thumbnailFilter.js",
        "website/js/ThumbnailFixer/thumbnailFixer.js",

        "website/js/YouTubeBlocking/youtubeBlockingManager.js",
        "website/js/DisableInfinityScrollShorts/disableInfinityScrollsShorts.js"
      ],

      "matches": ["*://www.youtube.com/*", "*://m.youtube.com/*"],

      "css": ["website/css/block.css"],

      "run_at": "document_start"
    },

    {
      "all_frames": true,

      "js": [
        "website/js/SkipVideoAds/skipVideoAds.js",
        "website/js/ShowNativePlayer/showNativePlayer.js",
        "website/js/DisableVideoAutoPlay/disableVideoAutoPlay.js",
        "website/js/BlockExtensionObserver/blockExtensionObserver.js",
        "website/js/BlockExtensionObserver/enableExtensionObserver.js"
      ],

      "matches": ["*://www.youtube.com/*", "*://m.youtube.com/*"],

      "run_at": "document_end"
    },

    {
      "all_frames": true,

      "js": [
        "website/js/web-accessible-resources/setVideoQuality.js",
        "website/js/VideoSummarize/summarize-functionality/timestamp-summary.js",
        "website/js/VideoSummarize/summarize-functionality/key-insight-summary.js",
        "website/js/VideoSummarize/summarize-functionality/transcription-summary.js",
        "website/js/VideoSummarize/summarize-functionality/top-comments-summary.js"
      ],

      "matches": ["*://www.youtube.com/*", "*://m.youtube.com/*"],

      "run_at": "document_idle"
    },

    {
      "all_frames": true,

      "js": [
        "website/js/ContentFilter/Desktop/contentFilterDesktop_helpers.js",
        "website/js/ContentFilter/Desktop/contentFilterDesktop_blocker.js",
        "website/js/ContentFilter/Desktop/contentFilterDesktop_contextButtons.js",
        "website/js/Shortcuts/shortcutsListener.js",
        "website/js/Dynamic/dynamicLeftBar.js"
      ],

      "css": ["website/css/desktop/desktop_summarize.css"],

      "matches": ["*://www.youtube.com/*"],

      "run_at": "document_start"
    },

    {
      "all_frames": true,

      "js": [
        "website/js/ContentFilter/Mobile/contentFilterMobile_helpers.js",
        "website/js/ContentFilter/Mobile/contentFilterMobile_blocker.js",
        "website/js/ContentFilter/Mobile/contentFilterMobile_contextButtons.js"
      ],

      "css": ["website/css/mobile/mobile_summarize.css"],

      "matches": ["*://m.youtube.com/*"],

      "run_at": "document_start"
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/toolbar-icon-16.png",
      "19": "images/toolbar-icon-19.png",
      "32": "images/toolbar-icon-32.png",
      "38": "images/toolbar-icon-38.png",
      "48": "images/toolbar-icon-48.png",
      "72": "images/toolbar-icon-72.png"
    }
  },

  "web_accessible_resources": [
    {
      "resources": [
        "website/js/web-accessible-resources/setVideoQuality.js",
        "website/js/web-accessible-resources/timeStampClick.js",
        "website/js/web-accessible-resources/skipAdsOverrideClickEvent.js"
      ],
      "matches": ["*://www.youtube.com/*", "*://m.youtube.com/*"]
    },
    {
      "resources": ["extension/screens/privacyPolicy/privacyPolicyForTab.js"],
      "matches": ["<all_urls>"]
    }
  ],

  "permissions": ["storage", "activeTab"]
}
