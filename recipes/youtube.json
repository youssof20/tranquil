{
  "defaultFeatures": {
  "hide_feed": true,
  "hide_sidebar": true,
  "hide_recommended": true,
  "hide_comments": false,
  "hide_endscreen": true,
  "hide_shorts": true,
  "hide_trending": false,
  "redirect_home": false,
  "hide_notifs": true
},
  "meta": {
    "id": "youtube",
    "name": "YouTube",
    "match": "*://*.youtube.com/*",
    "version": "1"
  },
  "features": [
    { "id": "hide_feed", "label": "Hide feed", "group": "Feed" },
    { "id": "hide_sidebar", "label": "Hide sidebar", "group": "Feed" },
    { "id": "hide_recommended", "label": "Hide recommended / related", "group": "Feed" },
    { "id": "hide_comments", "label": "Hide comments", "group": "Comments" },
    { "id": "hide_endscreen", "label": "Hide end screen (suggested videos in player)", "group": "Extras" },
    { "id": "hide_shorts", "label": "Hide Shorts", "group": "Extras" },
    { "id": "hide_trending", "label": "Block Trending / Explore", "group": "Extras" },
    { "id": "redirect_home", "label": "Redirect home to Subscriptions", "group": "Extras" },
    { "id": "hide_notifs", "label": "Hide notifications", "group": "Extras" }
  ],
  "rules": [
    { "featureId": "hide_feed", "attribute": "data-tranquil-hide-feed", "selectors": [
      "ytd-browse[page-subtype=home] .ytd-rich-grid-renderer",
      "ytd-browse[role=main]:not([page-subtype]):has(ytd-feed-filter-chip-bar-renderer) .ytd-rich-grid-renderer",
      "div[tab-identifier=FEwhat_to_watch]",
      "div#home-page-skeleton"
    ]},
    { "featureId": "hide_sidebar", "attribute": "data-tranquil-hide-sidebar", "selectors": [
      "#secondary.ytd-watch-flexy",
      "#secondary.ytd-watch-grid"
    ]},
    { "featureId": "hide_recommended", "attribute": "data-tranquil-hide-recommended", "selectors": [
      "#items.ytd-watch-next-secondary-results-renderer",
      ".ytd-watch-grid #contents",
      ".ytp-pause-overlay",
      "ytm-item-section-renderer[section-identifier=related-items]"
    ]},
    { "featureId": "hide_comments", "attribute": "data-tranquil-hide-comments", "selectors": [
      "#comment-teaser",
      "#comments",
      "ytm-comment-section-renderer",
      "ytm-comments-entry-point-header-renderer",
      "ytm-engagement-panel"
    ]},
    { "featureId": "hide_endscreen", "attribute": "data-tranquil-hide-endscreen", "selectors": [
      ".ytp-ce-element",
      ".html5-endscreen:not(.mweb-endscreen)",
      ".ytp-mweb-endscreen-play-next",
      ".ytp-mweb-endscreen-play-previous"
    ]},
    { "featureId": "hide_shorts", "attribute": "data-tranquil-hide-shorts", "selectors": [
      ".yt-simple-endpoint[title=Shorts]",
      "ytm-pivot-bar-renderer > ytm-pivot-bar-item-renderer:has(.pivot-shorts)",
      "div[tab-identifier=FEsubscriptions]",
      "#player-shorts-container",
      ".ytd-shorts",
      "ytd-reel-shelf-renderer",
      "ytd-rich-grid-renderer[is-shorts-grid]",
      "ytd-rich-item-renderer:has(a[href*=\"/shorts/\"])",
      "ytd-rich-shelf-renderer[is-shorts]",
      "ytd-video-renderer:has(a[href*=\"/shorts/\"])",
      "ytm-reel-shelf-renderer",
      "ytm-rich-grid-renderer.is_shorts",
      "ytm-video-with-context-renderer:has(a[href*=\"/shorts/\"])"
    ]},
    { "featureId": "hide_trending", "attribute": "data-tranquil-hide-trending", "selectors": [
      ".yt-simple-endpoint[href^=\"/feed/explore\"]",
      ".yt-simple-endpoint[href^=\"/feed/trending\"]",
      "ytd-browse[page-subtype=trending]",
      "ytm-pivot-bar-renderer > ytm-pivot-bar-item-renderer:has(.pivot-trending)",
      "div[tab-identifier=FEexplore]",
      "div[tab-identifier=FEtrending]"
    ]},
    { "featureId": "hide_notifs", "attribute": "data-tranquil-hide-notifs", "selectors": [
      "#buttons.ytd-masthead > ytd-notification-topbar-button-renderer",
      "ytd-notification-topbar-button-shape-renderer"
    ]}
  ],
  "reflow": [
    {
      "whenHidden": ["hide_sidebar"],
      "css": "html[data-tranquil-hide-sidebar=\"true\"] ytd-watch-flexy[flexy]:not([fullscreen]):not([theater]) #primary.ytd-watch-flexy { margin: 0 auto !important; max-width: 100% !important; } html[data-tranquil-hide-sidebar=\"true\"] ytd-watch-flexy[flexy]:not([fullscreen]):not([theater]) { --ytd-watch-flexy-max-player-width: 100% !important; }"
    }
  ]
}
